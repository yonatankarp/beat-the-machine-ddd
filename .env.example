# Word generator: seed | ollama | openai
BTM_PROMPT_PROVIDER=ollama
# Must match the prompt provider so Spring AI wires the ChatClient.Builder (seed -> leave unset/none):
SPRING_AI_MODEL_CHAT=ollama
OLLAMA_MODEL=llama3.2
SPRING_AI_OLLAMA_BASE_URL=http://ollama:11434
# For openai words instead: BTM_PROMPT_PROVIDER=openai, SPRING_AI_MODEL_CHAT=openai, SPRING_AI_OPENAI_API_KEY=sk-...

# Image generator: seed | local-sd | paid
# Linux + NVIDIA: run `docker compose --profile sd up` and set:
#   BTM_IMAGE_PROVIDER=local-sd
#   BTM_IMAGE_LOCAL_SD_BASE_URL=http://stable-diffusion:7860
# macOS (no container GPU): run Automatic1111 natively (--api) and set:
#   BTM_IMAGE_PROVIDER=local-sd
#   BTM_IMAGE_LOCAL_SD_BASE_URL=http://host.docker.internal:7860
# Paid images: BTM_IMAGE_PROVIDER=paid, SPRING_AI_MODEL_IMAGE=openai, SPRING_AI_OPENAI_API_KEY=sk-...
# (local-sd needs NO Spring AI, so leave SPRING_AI_MODEL_IMAGE unset for it.)
BTM_IMAGE_PROVIDER=seed
